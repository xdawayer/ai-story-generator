# --- LLM provider: Azure OpenAI (GPT) ---
# Copy values from gengrowth-agents/.env.local into your own .env.local
# (.env.local is gitignored and never committed).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_VERSION=2025-03-01-preview

# --- Campaign persistence: Supabase (the moat) ---
# Create a NEW, isolated Supabase project, then paste its keys here.
# In Authentication → Sign In / Providers, enable "Anonymous sign-ins".
# Run supabase/migrations/0001_init.sql in the SQL editor.
# The app runs fine without these (free NPC generator); saving is just disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is NOT needed yet (we use anon + RLS). Add only if/when you
# build server-only admin paths — and never expose it to the client.
# SUPABASE_SERVICE_ROLE_KEY=
