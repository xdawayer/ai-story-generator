# --- LLM provider: DeepSeek (OpenAI-compatible) ---
# Create a key at https://platform.deepseek.com/api_keys and paste it below.
# (.env.local is gitignored and never committed.)
DEEPSEEK_API_KEY=
# Optional overrides — safe to leave unset:
# DEEPSEEK_BASE_URL defaults to https://api.deepseek.com
# DEEPSEEK_MODEL defaults to deepseek-chat (use deepseek-chat, not deepseek-reasoner,
# for streaming prose).
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# --- Analytics: Google Analytics 4 (optional) ---
# Create a GA4 property at https://analytics.google.com (Admin -> Create property),
# add a Web data stream for the site, then paste the Measurement ID (G-XXXXXXXXXX).
# Leave unset to disable GA entirely (e.g. local dev).
NEXT_PUBLIC_GA_ID=

# --- Campaign persistence: Supabase (the moat) ---
# This app SHARES an existing Supabase project, isolated in its own `storygen`
# schema (the free tier caps you at 2 projects total per account). Paste the
# HOST project's URL + anon key below. In that project's dashboard:
#   1. Authentication → Sign In / Providers → enable "Anonymous sign-ins".
#   2. Settings → API → Exposed schemas → add `storygen`.
#   3. Apply BOTH migrations in order (supabase db push, or paste in SQL editor):
#        supabase/migrations/20260629000001_init.sql      (schema + campaigns + npcs)
#        supabase/migrations/20260629000002_sessions.sql  (session log)
# NOTE: enabling anonymous sign-ins is project-wide — confirm the host project's
# OTHER tables all have correct RLS so anonymous users can't reach them.
# The app runs fine without these (free NPC generator); saving is just disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is NOT needed yet (we use anon + RLS). Add only if/when you
# build server-only admin paths — and never expose it to the client.
# SUPABASE_SERVICE_ROLE_KEY=
